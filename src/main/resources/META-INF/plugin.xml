<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <id>com.github.darleywey.committranslator</id>
    <name>Commit Translator</name>
    <vendor email="darleywey@gmail.com" url="https://github.com/Darley-Wey">Darley Wey</vendor>

    <depends>com.intellij.modules.platform</depends>
    <depends>Git4Idea</depends>

    <resource-bundle>messages.CommitTranslatorBundle</resource-bundle>

    <extensions defaultExtensionNs="com.intellij">
        <!-- Settings -->
        <applicationConfigurable
                parentId="tools"
                instance="com.github.darleywey.committranslator.settings.CommitTranslatorConfigurable"
                id="com.github.darleywey.committranslator.settings.CommitTranslatorConfigurable"
                displayName="Commit Translator"/>
    </extensions>

    <actions>
        <!-- Translate Commit Message Action -->
        <action id="CommitTranslator.TranslateCommitMessage"
                class="com.github.darleywey.committranslator.actions.TranslateCommitMessageAction"
                text="Translate to English"
                description="Translate commit message to English using AI"
                icon="/icons/translate.svg">
            <add-to-group group-id="Vcs.MessageActionGroup" anchor="first"/>
        </action>
    </actions>
</idea-plugin>
